<div class="container-fluid mt-5 pt-3">
    <div class="container">
        <div class="section-title">
            <h4 class="m-0 text-uppercase font-weight-bold">Tất cả danh mục</h4>
        </div>
        <div class="row g-4">
            <% categories.forEach(cat => { %>
                <div class="col-lg-4 col-md-6 mb-4">
                    <a href="/category/<%= cat.id %>" class="text-decoration-none">
                        <div class="bg-white border p-5 text-center h-100 shadow-sm hover-effect">
                            <i class="fa fa-folder-open text-primary mb-3" style="font-size: 3rem;"></i>
                            <h4 class="font-weight-bold text-secondary text-uppercase"><%= cat.name %></h4>
                            <p class="m-0 text-muted">Bấm để xem tất cả bài viết</p>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<style>
    .hover-effect:hover {
        background-color: #f8f9fa !important;
        border-color: #ed1c24 !important;
        transition: 0.3s;
    }
</style>