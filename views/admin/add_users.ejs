<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0" style="max-width: 600px; margin: auto;">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Thêm Người Dùng Mới</h4>
        </div>
        <div class="card-body p-4">
            <form action="/admin/users_management/add" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên người dùng (Email)</label>
                    <input type="email" name="username" class="form-control" placeholder="example@gmail.com" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/admin/users_management" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>