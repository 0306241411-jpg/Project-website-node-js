<div class="container-fluid mt-5 pt-3">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section-title">
                    <h4 class="m-0 text-uppercase font-weight-bold">Danh mục: <%= categoryName %></h4>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="position-relative border bg-white h-100 d-flex flex-column shadow-sm">
                            <img class="img-fluid w-100" src="/img/<%= post.image %>" 
                                 style="height: 220px; object-fit: cover;" alt="<%= post.title %>">
                            
                            <div class="p-4 flex-grow-1">
                                <div class="mb-2">
                                    <small class="text-muted">
                                        <i class="far fa-calendar-alt mr-2"></i>
                                        <%= new Date(post.created_at).toLocaleDateString('vi-VN') %>
                                    </small>
                                </div>
                                <a class="h4 d-block mb-3 text-secondary text-uppercase font-weight-bold text-decoration-none" 
                                   href="/single/<%= post.id %>" 
                                   style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2;-webkit-box-orient: vertical; overflow: hidden;">
                                    <%= post.title %>
                                </a>
                                <p class="m-0 text-muted small" style="display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    <%- post.content.replace(/<[^>]*>/g, '') %>
                                </p>
                            </div>

                            <div class="d-flex justify-content-between bg-white border-top p-4">
                                <div class="d-flex align-items-center">
                                    <img class="rounded-circle mr-2" src="/img/user.jpg" width="25" height="25">
                                    <small>Admin</small>
                                </div>
                                <div class="d-flex align-items-center text-muted">
                                    <small class="ml-3"><i class="far fa-eye mr-2"></i>1,234</small>
                                    <small class="ml-3"><i class="far fa-comment mr-2"></i>12</small>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <h5 class="text-muted italic">Chưa có bài viết nào trong chủ đề này.</h5>
                </div>
            <% } %>
        </div>

        <% if (totalPages > 1) { %>
            <div class="row mt-5 pb-5">
                <div class="col-12">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link py-2 px-3 text-danger border-danger" 
                                   href="/category/<%= catId %>?page=<%= currentPage - 1 %>">
                                    &laquo; Trước
                                </a>
                            </li>

                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link py-2 px-3 <%= currentPage === i ? 'bg-danger border-danger text-white' : 'text-danger border-danger' %>" 
                                       href="/category/<%= catId %>?page=<%= i %>">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>

                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link py-2 px-3 text-danger border-danger" 
                                   href="/category/<%= catId %>?page=<%= currentPage + 1 %>">
                                    Sau &raquo;
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        <% } %>
    </div>
</div>