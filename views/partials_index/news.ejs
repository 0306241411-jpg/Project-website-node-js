<div class="container-fluid mt-5 pt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="section-title">
                    <h4 class="m-0 text-uppercase font-weight-bold">Tất cả bài viết</h4>
                </div>

                <% posts.forEach(post => { %>
                    <div class="d-flex align-items-center bg-white mb-3 border" style="height: 160px;">
                        <img class="img-fluid" src="/img/<%= post.image %>" style="width: 160px; height: 160px; object-fit: cover;">
                        <div class="w-100 h-100 px-3 d-flex flex-column justify-content-center border-left-0">
                            <div class="mb-2">
                                <span class="badge badge-primary text-uppercase p-1 mr-2"><%= post.category_name %></span>
                                <small class="text-muted"><%= new Date(post.created_at).toLocaleDateString('vi-VN') %></small>
                            </div>
                            <a class="h5 m-0 text-secondary text-uppercase font-weight-bold text-decoration-none" href="/single/<%= post.id %>">
                                <%= post.title %>
                            </a>
                            <p class="m-0 small text-muted mt-2" style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2;-webkit-box-orient: vertical; overflow: hidden;">
                                <%- post.content.replace(/<[^>]*>/g, '') %>
                            </p>
                        </div>
                    </div>
                <% }) %>

                <% if (totalPages > 1) { %>
                    <nav class="mt-5 pb-5">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link py-2 px-3 text-danger border-danger" href="/news?page=<%= currentPage - 1 %>">&laquo; Trước</a>
                            </li>
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link py-2 px-3 <%= currentPage === i ? 'bg-danger border-danger text-white' : 'text-danger border-danger' %>" href="/news?page=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link py-2 px-3 text-danger border-danger" href="/news?page=<%= currentPage + 1 %>">Sau &raquo;</a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            </div>
            
            <div class="col-lg-4">
    
    <div class="mb-3">
        <div class="section-title mb-0">
            <h4 class="m-0 text-uppercase font-weight-bold">Xu hướng</h4>
        </div>
        <div class="bg-white border border-top-0 p-3">
            <% trending.forEach(item => { %>
                <div class="d-flex align-items-center bg-white mb-3" style="height: 80px;">
                    <img class="img-fluid" src="/img/<%= item.image %>" style="width: 80px; height: 80px; object-fit: cover;">
                    <div class="w-100 h-100 px-3 d-flex flex-column justify-content-center border border-left-0">
                        <a class="h6 m-0 text-secondary text-uppercase font-weight-bold small text-decoration-none" 
                           href="/single/<%= item.id %>"
                           style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2;-webkit-box-orient: vertical; overflow: hidden;">
                            <%= item.title %>
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
                <div class="mb-3">
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Bản tin</h4>
                    </div>
                    <div class="bg-white text-center border border-top-0 p-3">
                        <p>Đăng ký để nhận những cập nhật mới nhất về tin tức và bài viết của chúng tôi.</p>
                        
                        <form action="/subscribe" method="POST">
                            <div class="input-group mb-2" style="width: 100%;">
                                <input type="email" name="email" class="form-control form-control-lg" placeholder="Email của bạn" required>
                                <div class="input-group-append">
                                    <button type="submit" class="btn btn-primary font-weight-bold px-3">Đăng ký</button>
                                </div>
                            </div>
                        </form>
                        <small class="text-muted">Chúng tôi cam kết không gửi thư rác.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>