<div class="container mt-5 pb-5"> 
    <div class="row mb-4">
        <div class="col-12">
            <div class="section-title">
                <h4 class="m-0 text-uppercase font-weight-bold">Bài viết mới nhất</h4>
                <a class="text-secondary font-weight-medium text-decoration-none" href="/news">Xem tất cả</a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center g-4"> 
    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
        <% posts.forEach(post => { %>
            <div class="col-md-4 mb-4"> 
                <div class="card h-100 shadow-sm border-0 bg-light">
                    <img src="/img/<%= post.image %>" class="card-img-top" alt="<%= post.title %>" style="height: 250px; object-fit: cover;">
                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold text-dark"><%= post.title %></h5>
                        <p class="card-text text-muted small mb-2">
                            <i class="bi bi-clock"></i> 
                            <%= post.created_at ? new Date(post.created_at).toLocaleDateString('vi-VN') : 'Vừa mới đây' %>
                        </p>
                        <div class="card-text text-muted mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            <%- post.content %>
                        </div>
                        <a href="single/<%= post.id %>" class="btn btn-outline-danger mt-auto">Đọc tiếp &rarr;</a>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col-12 text-center mt-5">
            <h4 class="text-muted">Hiện tại chưa có bài viết nào!</h4>
        </div>
    <% } %>
    </div> 
</div>